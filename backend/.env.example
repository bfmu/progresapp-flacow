# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=progresapp

# JWT — required: app won't start without this
JWT_SECRET=replace-with-a-64-char-hex-secret

# Google OAuth — Web (optional: leave empty to disable /auth/google endpoints)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Google OAuth — Mobile id_token (optional: leave empty to disable /auth/google/id-token endpoint)
GOOGLE_MOBILE_CLIENT_ID=

# Frontend base URL (used for OAuth callback redirect and password reset links)
FRONTEND_BASE_URL=http://localhost:4321

# TypeORM synchronize (set to false in production with manual migrations)
BACKEND_SYNCHRONIZE=true

# Mail
MAIL_HOST=
MAIL_PORT=
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=
