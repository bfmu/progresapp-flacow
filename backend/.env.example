# Server
PORT=3000

# Database (Postgres)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
# Set to "false" in production to avoid auto-syncing the schema
BACKEND_SYNCHRONIZE=true

# CORS
# Comma-separated list of allowed origins (e.g. web frontend, mobile dev client).
# Falls back to local-dev defaults (http://localhost:4321,http://localhost:81) if unset.
CORS_ORIGINS=http://localhost:4321,http://localhost:81

# Initial admin user (seeded on first run if it doesn't exist)
ADMIN_EMAIL=admin@flacow.com
ADMIN_PASSWORD=defaultpassword

# Frontend base URL (used to build links in emails, e.g. password reset)
FRONTEND_BASE_URL=http://localhost:4321

# SMTP (email notifications, e.g. password reset)
SMTP_HOST=
SMTP_PORT=587
# "true" or "false" — defaults to (port === 465) when unset
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_DEBUG=false
