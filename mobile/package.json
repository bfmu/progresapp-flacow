{
  "name": "progresapp-mobile",
  "version": "0.0.1",
  "private": true,
  "description": "Progresapp mobile app (React Native + Expo) — workout tracking and rest timer with push notifications",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "NODE_PATH=./node_modules jest",
    "test:watch": "NODE_PATH=./node_modules jest --watch"
  },
  "dependencies": {
    "@progresapp/shared": "*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "expo": "~51.0.0",
    "expo-constants": "~16.0.0",
    "expo-notifications": "~0.28.0",
    "expo-secure-store": "~13.0.0",
    "nativewind": "4.1.23",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "~12.7.2",
    "@types/react": "~18.2.79",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "react-test-renderer": "18.2.0",
    "tailwindcss": "^3.4.10",
    "typescript": "~5.3.3"
  },
  "jest": {
    "preset": "jest-expo",
    "moduleNameMapper": {
      "^react-native-css-interop/jsx-runtime$": "<rootDir>/src/__mocks__/react-native-css-interop-jsx-runtime.js",
      "^react-native-css-interop/jsx-dev-runtime$": "<rootDir>/src/__mocks__/react-native-css-interop-jsx-runtime.js",
      "^react-native-css-interop$": "<rootDir>/src/__mocks__/react-native-css-interop.js",
      "^react-native-css-interop/(.*)$": "<rootDir>/src/__mocks__/react-native-css-interop.js",
      "^react$": "<rootDir>/node_modules/react",
      "^react/jsx-runtime$": "<rootDir>/node_modules/react/jsx-runtime",
      "^@progresapp/shared/(.*)$": "<rootDir>/../packages/shared/src/$1"
    }
  }
}
