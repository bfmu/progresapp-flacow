{
  "name": "@progresapp/shared",
  "version": "0.0.1",
  "private": true,
  "description": "Shared TypeScript modules (API client, Zustand stores, types) for the Progresapp web and mobile apps",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    "./api/*": "./src/api/*.ts",
    "./store/*": "./src/store/*.ts",
    "./types/*": "./src/types/*.ts"
  },
  "scripts": {
    "test": "jest --config jest.config.ts",
    "test:watch": "jest --config jest.config.ts --watch",
    "test:cov": "jest --config jest.config.ts --coverage"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.2",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
